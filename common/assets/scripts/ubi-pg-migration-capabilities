#!/bin/bash
set -euo pipefail

# Emit this image's managed-Postgres migrator capability descriptor as JSON,
# but only when the advertised tools are actually installed and executable.
#
# The control-plane runner capability probe (SPEC 9.4) invokes this command over
# ssh and treats a nonzero exit -- or a missing command, on images predating the
# migrator -- as ineligible. The descriptor is baked at image build time from
# the exact pgcopydb/client packages staged into the runtime dpkg cache, so its
# versions never drift from what runtime dpkg installs. pgcopydb is only staged
# as a .deb at build and installed later by install-postgresql-packages, so this
# probe additionally confirms the tools are on disk: a VM whose install step has
# not run (or failed) reports ineligible instead of advertising a pgcopydb path
# that does not yet exist and failing at exec time.

DESCRIPTOR="/usr/local/share/ubi-pg-migration/capabilities.json"

if [[ ! -r "$DESCRIPTOR" ]]; then
    echo "migrator capability descriptor missing: $DESCRIPTOR" >&2
    exit 1
fi

# Fail closed unless every advertised binary is present and executable. These
# paths are fixed by PGDG packaging (pgcopydb in /usr/bin; per-major clients in
# their versioned bindir) and mirror the descriptor's pgcopydb.path/bin_dir.
required_bins=(
    /usr/bin/pgcopydb
    /usr/lib/postgresql/16/bin/psql
    /usr/lib/postgresql/17/bin/psql
    /usr/lib/postgresql/18/bin/psql
)
for bin in "${required_bins[@]}"; do
    if [[ ! -x "$bin" ]]; then
        echo "migrator tool not installed: $bin" >&2
        exit 1
    fi
done

cat "$DESCRIPTOR"
